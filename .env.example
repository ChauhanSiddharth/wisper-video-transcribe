# Copy this file to .env and adjust values as needed.

# Whisper model size: tiny | base | small | medium | large-v3
WHISPER_MODEL=base

# Inference device: cpu | cuda
WHISPER_DEVICE=cpu

# Quantisation: int8 (fast, low RAM) | float16 (GPU) | float32 (CPU, accurate)
WHISPER_COMPUTE_TYPE=int8

# Maximum video upload size in megabytes
MAX_FILE_SIZE_MB=500

# URL the Streamlit frontend uses to reach the FastAPI backend.
# Inside Docker (same container): http://localhost:8000
# Separate containers/hosts: http://<backend-host>:8000
BACKEND_URL=http://localhost:8000

# Port Streamlit listens on (Railway sets this automatically)
PORT=8501
